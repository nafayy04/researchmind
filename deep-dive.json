      "typeVersion": 1,
      "position": [272, 224],
      "id": "6b2a9355-002f-49be-923f-b1a914b22270",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "YOUR_GROQ_CREDENTIAL_ID",
          "name": "Groq account"
        }
      }
    },
    {
