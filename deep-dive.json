    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this research paper in detail:\n\nTitle: {{ $json.title }}\nAuthors: {{ $json.authors }}\nYear: {{ $json.year }}\nCitations: {{ $json.citations }}\nSource: {{ $json.source }}\n\nAbstract: {{ $json.abstract }}\n\nProvide comprehensive, paper-specific insights based on the content above. Do not ask for input. Analyze immediately.",
        "options": {
          "systemMessage": "You analyze research papers for PhD students. You ONLY analyze the paper provided. You are SPECIFIC and CONCRETE.\n\nFor THIS paper analyze:\n\n**Limitations:**\n- What are the methodology limitations of this paper?\n- What are the data or sample limitations?\n- What are the scope or generalizability issues?\n\n**Improvements:**\n- How could the methodology be enhanced?\n- How could the data collection be improved?\n- How could the findings be more applicable?\n\n**Future Research:**\n- What gaps does this paper reveal?\n- What extensions of this work are needed?\n- What related areas should be explored?\n\n**Methods to Try:**\n- What alternative methods could complement this study?\n- What techniques could address the limitations?\n\nRULES:\n- Reference specific details from THIS paper\n- Use specific terminology from the abstract\n- Do not use generic academic language\n- Be actionable and specific\n- Write for PhD students in this field"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [288, 0],
      "id": "e856aa35-a0bd-4fd4-ab0a-b5e51742fb43",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": "meta-llama/llama-4-scout-17b-16e-instruct",
        "options": {}
      },
